# Copy to .env and fill in values

# Local development — SQLite file in project root
DATABASE_URL="file:./dev.db"

# Production (Vercel) — use Turso (free tier: https://turso.tech)
# Do NOT use file:./ paths on Vercel — the filesystem is ephemeral.
# TURSO_DATABASE_URL="libsql://your-database-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Keep AUTH_SECRET stable — changing it invalidates existing login sessions.
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Comma-separated LAN IPs/hostnames for mobile dev testing (e.g. 192.168.0.106)
DEV_ALLOWED_ORIGINS="192.168.0.106"
