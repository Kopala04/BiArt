# Copy to .env and fill in values

DATABASE_URL="file:./dev.db"
# Keep this stable — changing it invalidates existing login cookies (sign in again).
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Comma-separated LAN IPs/hostnames for mobile dev testing (e.g. 192.168.0.106)
DEV_ALLOWED_ORIGINS="192.168.0.106"
