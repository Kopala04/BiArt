# Copy to .env and fill in values

# Local development — SQLite file in project root
DATABASE_URL="file:./dev.db"

# Production (Vercel) — use Turso (free tier: https://turso.tech)
# Do NOT use file:./ paths on Vercel — the filesystem is ephemeral.
# TURSO_DATABASE_URL="libsql://your-database-name-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Keep AUTH_SECRET stable — changing it invalidates existing login sessions.
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Comma-separated LAN IPs/hostnames for mobile dev testing (e.g. 192.168.0.106)
DEV_ALLOWED_ORIGINS="192.168.0.106"

# --- Media storage (admin uploads) ---
# Local dev: defaults to public/uploads (no extra config).
#
# Vercel production (required — db migrate alone is not enough):
# 1. Vercel Dashboard → Storage → Create Blob store
# 2. Connect store to this project (Production + Preview)
# 3. Redeploy — Vercel adds BLOB_STORE_ID (+ OIDC) or BLOB_READ_WRITE_TOKEN
#
# Provider: local | s3 | vercel-blob (auto on Vercel when Blob store is connected)
# MEDIA_STORAGE_PROVIDER="local"
# MEDIA_MAX_IMAGE_BYTES=10485760
# MEDIA_MAX_VIDEO_BYTES=52428800
# MEDIA_UPLOAD_TIMEOUT_MS=120000
# MEDIA_UPLOAD_RATE_LIMIT_PER_MINUTE=30
# MEDIA_ADMIN_PAGE_SIZE=24
# MEDIA_IDEMPOTENCY_TTL_HOURS=24
# MEDIA_LOCAL_ROOT="public/uploads"
# MEDIA_LOCAL_PUBLIC_BASE="/uploads"

# Vercel Blob (auto when store is connected to the project)
# BLOB_READ_WRITE_TOKEN=""   # legacy static token
# BLOB_STORE_ID=""           # OIDC — set automatically when Blob store is connected

# S3-compatible storage (AWS S3, Cloudflare R2, MinIO)
# MEDIA_STORAGE_PROVIDER="s3"
# S3_BUCKET="biart-media"
# S3_REGION="auto"
# S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_PUBLIC_URL_BASE="https://media.example.com"
# S3_FORCE_PATH_STYLE="true"
