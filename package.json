{
  "name": "bi-art",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev --hostname 0.0.0.0",
    "dev:local": "prisma generate && next dev",
    "build": "bash scripts/build.sh",
    "start": "next start",
    "start:network": "next start --hostname 0.0.0.0",
    "start:test": "bash scripts/start-test-server.sh",
    "start:mobile": "npm run build && npm run start:network",
    "lint": "eslint",
    "test:setup": "playwright install chromium webkit",
    "pretest:e2e": "bash scripts/ensure-playwright-browsers.sh",
    "pretest:ci": "bash scripts/ensure-playwright-browsers.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:ci": "playwright test --project=chromium-desktop --project=mobile-chrome",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "arial-geo": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
